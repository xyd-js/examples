{
  "theme": {
    "name": "poetry",
    "appearance": {
      "colorScheme": "light"
    }
  },
  "accessControl": {
    "provider": {
      "type": "jwt",
      "loginUrl": "/login",
      "callbackPath": "/auth/jwt-callback",
      "algorithm": "HS256",
      "secret": "$AUTH_SECRET",
      "groupsClaim": "groups"
    },
    "defaultAccess": "public",
    "rules": [
      { "match": "/protected/**", "access": "protected" },
      { "match": "/admin/**", "access": "protected", "groups": ["admin"] }
    ],
    "login": {
      "logo": "/public/logo.svg",
      "title": "Sign in to access documentation",
      "description": "Some pages require authentication."
    },
    "session": {
      "maxAge": 86400,
      "cookieName": "xyd-auth-token"
    }
  },
  "navigation": {
    "sidebar": [
      {
        "route": "guides",
        "pages": [
          {
            "group": "Public Pages",
            "pages": [
              "guides/welcome",
              "guides/getting-started",
              "guides/faq"
            ]
          }
        ]
      },
      {
        "route": "protected",
        "pages": [
          {
            "group": "Protected Pages",
            "icon": "lock",
            "pages": [
              "protected/api-reference",
              "protected/internal-guide"
            ]
          }
        ]
      },
      {
        "route": "admin",
        "pages": [
          {
            "group": "Admin Pages",
            "icon": "shield",
            "pages": [
              "admin/dashboard",
              "admin/user-management"
            ]
          }
        ]
      }
    ]
  }
}
