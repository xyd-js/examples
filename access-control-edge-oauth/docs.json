{
  "theme": {
    "name": "poetry",
    "appearance": {
      "colorScheme": "light"
    }
  },
  "accessControl": {
    "provider": {
      "type": "oauth",
      "authorizationUrl": "http://localhost:4000/authorize",
      "tokenUrl": "http://localhost:4000/token",
      "clientId": "mock-client-id",
      "scopes": ["openid", "email", "profile"],
      "callbackPath": "/auth/callback",
      "userInfoUrl": "http://localhost:4000/userinfo",
      "groupsClaim": "roles"
    },
    "defaultAccess": "public",
    "rules": [
      { "match": "/protected/**", "access": "protected" },
      { "match": "/admin/**", "access": "protected", "groups": ["admin"] }
    ],
    "login": {
      "logo": "/public/logo.svg",
      "title": "Sign in with OAuth",
      "description": "This documentation requires authentication."
    },
    "deploy": {
      "platform": "node-edge"
    },
    "session": {
      "maxAge": 86400,
      "cookieName": "xyd-auth-token"
    }
  },
  "navigation": {
    "sidebar": [
      {
        "route": "guides",
        "pages": [
          {
            "group": "Public Pages",
            "pages": [
              "guides/welcome",
              "guides/getting-started",
              "guides/faq"
            ]
          }
        ]
      },
      {
        "route": "protected",
        "pages": [
          {
            "group": "Protected Pages",
            "icon": "lock",
            "pages": [
              "protected/api-reference",
              "protected/internal-guide"
            ]
          }
        ]
      },
      {
        "route": "admin",
        "pages": [
          {
            "group": "Admin Pages",
            "icon": "shield",
            "pages": [
              "admin/dashboard",
              "admin/user-management"
            ]
          }
        ]
      }
    ]
  }
}